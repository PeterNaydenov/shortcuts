{
  "name": "@peter.naydenov/shortcuts",
  "description": "Context control of shortcuts based on keyboard and mouse events",
  "version": "4.1.0",
  "license": "MIT",
  "author": "Peter Naydenov",
  "main": "./src/main.js",
  "types": "./dist/main.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/shortcuts.esm.mjs",
      "require": "./dist/shortcuts.cjs",
      "default": "./dist/shortcuts.umd.js"
    },
    "./package.json": "./package.json",
    "./dist/*": "./dist/*",
    "./src/*": "./src/*"
  },
  "scripts": {
    "dev": "vite",
    "build": "rollup -c && npm run types",
    "test": "vitest",
    "test:ui": "vitest --ui --open",
    "cover": "vitest run --coverage",
    "types": "tsc",
    "lint": "eslint src/ test/*.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PeterNaydenov/shortcuts"
  },
  "dependencies": {
    "@peter.naydenov/notice": "^2.4.2"
  },
  "devDependencies": {
    "@peter.naydenov/visual-controller-for-react": "^3.1.2",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "ask-for-promise": "^3.1.1",
    "eslint": "^10.5.0",
    "playwright": "^1.60.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.7",
    "rollup": "^4.62.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "shortcut",
    "key",
    "keyboard",
    "mouse",
    "click"
  ],
  "allowScripts": {
    "fsevents@2.3.2": true,
    "fsevents@2.3.3": true
  }
}
